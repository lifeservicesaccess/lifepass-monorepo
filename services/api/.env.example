# LifePass API environment template
# Copy to services/api/.env.local and fill values.

# API runtime
PORT=3003
API_KEY=
STARTUP_STRICT=0

# CORS allowlist for browser clients (comma-separated origins)
# Example: https://your-web.vercel.app,https://lifepass.app
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=0

# Blockchain config (leave empty in simulated/local mode)
RPC_URL=
PRIVATE_KEY=
SBT_CONTRACT_ADDRESS=
AGE_VERIFIER_ADDRESS=

# Optional persistence
PG_CONNECTION_STRING=
DATABASE_URL=

# ZK settings
USE_SNARKJS=0
SNARK_WASM_PATH=
SNARK_ZKEY_PATH=
SNARK_VKEY_PATH=
