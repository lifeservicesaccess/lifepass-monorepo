# LifePass API environment template
# Copy to services/api/.env.local and fill values.

# API runtime
PORT=3003
API_KEY=
STARTUP_STRICT=0

# CORS allowlist for browser clients (comma-separated origins)
# Example: https://your-web.vercel.app,https://lifepass.app
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=0

# Blockchain config (leave empty in simulated/local mode)
RPC_URL=
PRIVATE_KEY=
SBT_CONTRACT_ADDRESS=
AGE_VERIFIER_ADDRESS=
# Set to 1 to require AGE_VERIFIER_ADDRESS in startup checks
REQUIRE_AGE_VERIFIER=0

# Optional persistence
PG_CONNECTION_STRING=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=lifepass-assets
S3_BUCKET=
S3_REGION=

# Trust score defaults
TRUST_SCORE_DEFAULT=35

# Optional AI model key for /ai/chat model-backed mode
OPENAI_API_KEY=

# Sprint 2 SSO/JWT settings
LIFEPASS_SSO_JWT_SECRET=
LIFEPASS_SSO_JWT_ISSUER=lifepass-api
LIFEPASS_SSO_DEFAULT_AUDIENCE=zionstack-portals
LIFEPASS_SSO_JWT_EXPIRES_IN=15m

# Sprint 2.2 portal policy and audit
# JSON object override for covenant/policy trust thresholds
LIFEPASS_PORTAL_POLICY_JSON=
# Max retained rows in services/data/portal-access-audit.json
PORTAL_ACCESS_AUDIT_MAX_ROWS=2000
# Required to authorize POST /portals/policy-matrix and GET /portals/policy-admin/audit
POLICY_ADMIN_KEY=
# Max retained rows in services/data/portal-policy-admin-audit.json
POLICY_ADMIN_AUDIT_MAX_ROWS=2000
# Max retained rows in services/data/portal-policy-snapshots.json
POLICY_SNAPSHOT_MAX_ROWS=500
# Defaults for GET /portals/access-audit/alerts (query params can override)
PORTAL_DENY_ALERT_THRESHOLD=10
PORTAL_DENY_ALERT_WINDOW_MINUTES=60

# ZK settings
USE_SNARKJS=0
SNARK_WASM_PATH=
SNARK_ZKEY_PATH=
SNARK_VKEY_PATH=
