{
  "name": "lifepass-api",
  "version": "0.1.0",
  "scripts": {
    "start": "node index.js",
    "start:dev": "nodemon index.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "db:migrate": "node scripts/run_migrations.js",
    "check:schema": "node scripts/check_schema.js",
    "validate:snark": "node scripts/validate_snark_artifacts.js",
    "deploy:sbt": "node scripts/deploy_contract.js",
    "deploy:sbt:dry": "node -e \"const m=require('./scripts/deploy_contract'); process.env.DEPLOY_DRY_RUN='1'; m.deploy().then((r)=>{console.log('Deploy result', r);}).catch((e)=>{console.error('Deploy failed:', e); process.exit(1);});\""
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.8.1",
    "express": "^4.18.2",
    "express-validator": "^6.15.0",
    "pg": "^8.11.0",
    "snarkjs": "^0.7.5",
    "solc": "^0.8.0"
  }
}
