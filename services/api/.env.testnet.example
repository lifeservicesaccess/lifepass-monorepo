# LifePass API testnet template
# Copy to services/api/.env.local for real on-chain mode.

PORT=3003
API_KEY=
STARTUP_STRICT=1
USE_SNARKJS=0
SNARK_WASM_PATH=
SNARK_ZKEY_PATH=
SNARK_VKEY_PATH=

# CORS allowlist for browser clients (comma-separated origins)
# Example: https://your-web.vercel.app,https://lifepass.app
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=0

# Required for real testnet minting
RPC_URL=https://your-testnet-rpc.example
PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
SBT_CONTRACT_ADDRESS=0xYOUR_40_HEX_CONTRACT_ADDRESS

# Optional on-chain verifier
AGE_VERIFIER_ADDRESS=
# Set to 1 to enforce AGE_VERIFIER_ADDRESS during readiness/startup strict checks
REQUIRE_AGE_VERIFIER=0

# Optional persistence
PG_CONNECTION_STRING=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Trust score defaults
TRUST_SCORE_DEFAULT=35

# Sprint 2 SSO/JWT settings
LIFEPASS_SSO_JWT_SECRET=
LIFEPASS_SSO_JWT_ISSUER=lifepass-api
LIFEPASS_SSO_DEFAULT_AUDIENCE=zionstack-portals
LIFEPASS_SSO_JWT_EXPIRES_IN=15m

# Sprint 2.2 portal policy and audit
LIFEPASS_PORTAL_POLICY_JSON=
PORTAL_ACCESS_AUDIT_MAX_ROWS=2000
POLICY_ADMIN_KEY=
POLICY_ADMIN_AUDIT_MAX_ROWS=2000
POLICY_SNAPSHOT_MAX_ROWS=500
PORTAL_DENY_ALERT_THRESHOLD=10
PORTAL_DENY_ALERT_WINDOW_MINUTES=60

# Optional AI model key for /ai/chat model-backed mode
OPENAI_API_KEY=
