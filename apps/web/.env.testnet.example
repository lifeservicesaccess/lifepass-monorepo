# LifePass Web testnet template
# Copy to apps/web/.env.local for real wallet UX.

# Required for RainbowKit/WalletConnect in testnet mode
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Required in deployed environments (e.g., Vercel): public HTTPS URL of the API service.
# For local dev you may keep this empty and use LOCAL_API_BASE_URL rewrites.
NEXT_PUBLIC_API_BASE_URL=

# Optional local API proxy target used by Next.js rewrites during development only.
LOCAL_API_BASE_URL=http://localhost:3003
