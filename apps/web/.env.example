# LifePass Web environment template
# Copy to apps/web/.env.local and fill values.

# Required for RainbowKit/WalletConnect in testnet mode
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Required in deployed environments (e.g., Vercel): public HTTPS URL of the API service.
# Leave empty for local dev and Next.js rewrites will proxy /proof, /sbt, /flow.
NEXT_PUBLIC_API_BASE_URL=

# Server-side env for Next.js API proxies. In Vercel, set these as standard env vars
# so browser clients never see the secret.
API_BASE_URL=
API_KEY=

# Optional local API proxy target used by Next.js rewrites during development only.
LOCAL_API_BASE_URL=http://localhost:3003
