# ──────────────────────────────────────────────────────────────────────────────
# LifePass Contracts – environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Deployer wallet – this address must hold enough Amoy MATIC/POL to cover gas.
# See docs/FUNDING.md for faucet instructions.
DEPLOYER_ADDRESS=0x8644010A2B94441c1e4e524e8a3b20395d1A84b6

# Private key for the deployer wallet (hex, no 0x prefix).
# Keep this secret – never commit or share it.
DEPLOYER_PRIVATE_KEY=

# Polygon Amoy testnet RPC endpoint.
# Free options:
#   https://rpc-amoy.polygon.technology
#   https://polygon-amoy.infura.io/v3/<PROJECT_ID>
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygon mainnet RPC endpoint (for production).
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API key – used for contract verification.
# Obtain one at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=
